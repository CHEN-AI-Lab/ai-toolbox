# ===== Project ENV Template =====
# Copy this file to .env.local in each app directory that needs it
# cp apps/web/.env.example apps/web/.env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=AI Toolbox

# AI API (SenseTime/OpenAI compatible)
AI_API_KEY=***n
AI_BASE_URL=https://token.sensenova.cn/v1
AI_MODEL=sensenova-6.7-flash-lite

# Database (optional - Supabase)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Payment (optional - Creem)
# CREEM_API_KEY=your-creem-api-key
